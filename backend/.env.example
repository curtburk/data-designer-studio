# NVIDIA hosted mode
NVIDIA_API_KEY=nvapi-REPLACE_ME

# Local mode - vLLM OpenAI-compatible endpoint on ZGX Nano
# Note: single-line pattern so start_services.sh can sed this reliably
LOCAL_VLLM_URL=http://192.168.10.123:8090/v1
LOCAL_VLLM_API_KEY=not-needed

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8765

# Budget limits
HOSTED_RPM_LIMIT=40
LOCAL_RPM_LIMIT=120
DAILY_JOB_SOFT_LIMIT=100

# Storage
ARTIFACT_PATH=/var/lib/ddstudio/artifacts
DB_PATH=/var/lib/ddstudio/ddstudio.db

# Feature flags
ENABLE_COST_COUNTER=true
LOG_LEVEL=INFO
